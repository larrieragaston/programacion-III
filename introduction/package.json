{
  "name": "programacion-III-introduction",
  "private": true,
  "scripts": {
    "dev": "slidev",
    "build": "slidev build --base /programacion-III/introduction/",
    "clean:exports": "rm -f pdfs/exports/*.pdf slides-export.pdf *-slides-export.pdf *-export.pdf",
    "export": "npm run clean:exports && mkdir -p pdfs/exports && slidev export --output pdfs/exports/introduction-slides-export.pdf"
  },
  "dependencies": {
    "@slidev/cli": "^52.14.1",
    "@slidev/theme-bricks": "^0.25.0"
  },
  "devDependencies": {
    "playwright-chromium": "^1.59.1"
  }
}
